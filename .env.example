# -----------------------------
# Docker Compose / Database
# -----------------------------
POSTGRES_USER=xno
POSTGRES_PASSWORD=xno_pass
POSTGRES_DB=xno_market

# -----------------------------
# Shared service config
# -----------------------------
DATABASE_URL=postgresql://xno:xno_pass@timescaledb:5432/xno_market?sslmode=disable
PORT=8080
VITE_API_BASE_URL=http://localhost:8080

# -----------------------------
# Ingestor: Binance endpoints
# -----------------------------
BINANCE_WS_URL=wss://fstream.binance.com
BINANCE_REST_URL=https://fapi.binance.com

# Comma-separated symbol list (top futures pairs)
SYMBOLS=BTCUSDT,ETHUSDT,ETHUSDC,BTCUSDC,SOLUSDT,XAUUSDT,XAGUSDT,REDUSDT,TRUUSDT,XRPUSDT,CLUSDT,ZECUSDT,DOGEUSDT,SIRENUSDT,TAOUSDT,1000PEPEUSDT,BULLAUSDT,PLAYUSDT,BNBUSDT,BZUSDT

# Ingestor runtime
LOG_LEVEL=info
BATCH_SIZE=100
FLUSH_INTERVAL_MS=50

# -----------------------------
# Startup behavior
# -----------------------------
START_WITH_BACKFILL=false
BACKFILL_TYPE=approx
BACKFILL_MINUTES=15
KEEP_UNREADY_TRADE=false
STARTUP_PRE_READY_TRADE_MODE=approx
# Allowed BACKFILL_TYPE: approx|null
# Allowed STARTUP_PRE_READY_TRADE_MODE: approx|null
# Validation rule:
# If START_WITH_BACKFILL=true and BACKFILL_TYPE=approx and KEEP_UNREADY_TRADE=true,
# then STARTUP_PRE_READY_TRADE_MODE must be approx.

# -----------------------------
# REST rate-limit protection
# Binance USD-M REQUEST_WEIGHT/min is commonly 2400 (verify via exchangeInfo)
# -----------------------------
REST_WEIGHT_PER_MIN=2400
REST_MAX_RETRIES=6
REST_BASE_BACKOFF_MS=1000
REST_MAX_BACKOFF_MS=30000
REST_BAN_COOLDOWN_SEC=120

# -----------------------------
# Auth
# -----------------------------
DASHBOARD_TOKEN=123